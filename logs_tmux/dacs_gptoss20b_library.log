    parts = []
    if key:
        parts.append("has key")
    if id_card:
        parts.append("has id card")
    parts.append(f"location: {location}")
    if heavy_door:
        parts.append("found heavy door")
    if unlocked:
        parts.append("door unlocked")
    return ", ".join(parts) + "."
