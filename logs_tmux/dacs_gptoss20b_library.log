def extract_state(game_history):
    card_catalog = "card catalog" in game_history.lower()
    key_obtained = "key obtained" in game_history.lower()
    door_unlocked = "door unlocked" in game_history.lower() or "unlocked" in game_history.lower()
    biography_taken = "biography" in game_history.lower() and ("taken" in game_history.lower() or "get biography" in game_history.lower())
    key_returned = "key returned" in game_history.lower()
    exited = "have left the library" in game_history.lower() or "you have left" in game_history.lower()
    milestones = []
    if card_catalog: milestones.append("card catalog obtained")
    if key_obtained: milestones.append("key obtained")
    if door_unlocked: milestones.append("rare books room door unlocked")
    if biography_taken: milestones.append("biography obtained")
    if key_returned: milestones.append("key returned")
    if exited: milestones.append("exited library")
    if not milestones:
        return "No milestones achieved."
    return " | ".join(milestones)
