def extract_state(game_history):
    state = []
    if "give card" in game_history.lower() or "give card catalog" in game_history.lower():
        state.append("key obtained")
    if "unlock door" in game_history.lower():
        state.append("door unlocked")
    if "open door" in game_history.lower():
        state.append("door open")
    if "rare books room" in game_history.lower() and ("enter" in game_history.lower() or "north" in game_history.lower()):
        state.append("entered Rare Books Room")
    if "get biography" in game_history.lower() or "take biography" in game_history.lower():
        state.append("biography taken")
    return ", ".join(state) + "." if state else "Unknown state."
