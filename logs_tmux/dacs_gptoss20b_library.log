def extract_state(game_history):
    key_present = False
    biography_present = False
    key_returned = None
    lines = game_history.lower().splitlines()
    for i, line in enumerate(lines):
        if line.startswith("you are carrying:"):
            j = i + 1
            while j < len(lines) and lines[j].strip():
                item = lines[j].strip()
                if "key" in item:
                    key_present = True
                if "biography" in item:
                    biography_present = True
                j += 1
    if "you really need to return that key" in game_history.lower():
        key_returned = False
    parts = []
    parts.append("Has key" if key_present else "No key")
    parts.append("Has biography" if biography_present else "No biography")
    if key_returned is False:
        parts.append("Key not returned")
    return ", ".join(parts)
