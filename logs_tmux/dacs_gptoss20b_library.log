def extract_state(game_history):
    key = "gives you the key" in game_history or "you have the key" in game_history
    door = "rare books door is unlocked" in game_history or "you open the rare books door" in game_history
    book = "you take the biography" in game_history or "taken" in game_history
    parts = []
    if key:
        parts.append("has key")
    if door:
        parts.append("door unlocked")
    if book:
        parts.append("book taken")
