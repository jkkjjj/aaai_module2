def extract_state(game_history):
    key = "gives you the key to the rare books room" in game_history
    id_card = "you take card" in game_history
    location = "unknown"
    if "second floor stacks" in game_history:
        location = "second floor stacks"
    elif "ground floor stacks" in game_history:
        location = "ground floor stacks"
    elif "lobby" in game_history:
        location = "lobby"
