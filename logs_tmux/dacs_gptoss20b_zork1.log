    if "large egg" in game_history:
        state.append("Egg collected")
    if "small window slightly ajar" in game_history or "open window" in game_history:
        state.append("Window opened")
    if "you are in the kitchen" in game_history or "kitchen" in game_history:
        state.append("House entered")
    if "lantern" in game_history and ("in the kitchen" in game_history or "in a sack" in game_history):
        state.append("Lantern obtained")
    if "knife" in game_history and ("in the kitchen" in game_history or "in a sack" in game_history):
        state.append("Knife obtained")
    return ", ".join(state) if state else "No milestones"
