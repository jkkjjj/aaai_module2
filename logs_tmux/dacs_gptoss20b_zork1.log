def extract_state(game_history):
    milestones = []
    if "open mailbox" in game_history and "you open the small mailbox" in game_history:
        milestones.append("Mailbox opened")
    if "read leaflet" in game_history and "welcome to zork" in game_history:
        milestones.append("Leaflet read")
    if "climb tree" in game_history and "you are about 10 feet above the ground" in game_history:
        milestones.append("Tree climbed")
    if "take egg" in game_history and "taken" in game_history.splitlines()[-1]:
        milestones.append("Egg taken")
    if "open window" in game_history and "you open the small window" in game_history:
        milestones.append("Window opened")
    if "enter window" in game_history and "you are in the kitchen" in game_history:
        milestones.append("Entered house")
    if "open sack" in game_history and "opening the brown sack reveals a lunch" in game_history:
        milestones.append("Sack opened")
    if "get lantern" in game_history and "lantern" in game_history:
        milestones.append("Lantern obtained")
    if "get knife" in game_history and "knife" in game_history:
        milestones.append("Knife obtained")
    return ", ".join(milestones) if milestones else "No milestones achieved"
