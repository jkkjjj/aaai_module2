def extract_state(game_history):
    milestones = []
    if "open mailbox" in game_history and "leaflet" in game_history:
        milestones.append("Mailbox opened")
    if "read leaflet" in game_history or ("leaflet" in game_history and "read" in game_history):
        milestones.append("Leaflet read")
    if ("take egg" in game_history or "egg" in game_history and "taken" in game_history) and "climb tree" in game_history:
        milestones.append("Egg collected")
    if "open window" in game_history or "look window" in game_history:
        milestones.append("Window opened")
    if "enter window" in game_history:
        milestones.append("Entered house")
    if ("get knife" in game_history or "take knife" in game_history) and ("attic" in game_history or "table" in game_history):
        milestones.append("Knife taken")
    if ("get lantern" in game_history or "take lantern" in game_history) and "trophycase" in game_history:
        milestones.append("Lantern taken")
    if "attic" in game_history:
        milestones.append("Attic visited")
    if "rope" in game_history and ("examine rope" in game_history or "look rope" in game_history):
        milestones.append("Rope examined")
    if not milestones:
        return "Unknown state."
    return "; ".join(milestones) + "."
