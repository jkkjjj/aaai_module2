def extract_state(game_history):
    milestones = []
    if "open mailbox" in game_history:
        milestones.append("opened mailbox")
    if "read leaflet" in game_history:
        milestones.append("read leaflet")
    if "take egg" in game_history:
        milestones.append("collected egg")
    if "open window" in game_history:
        milestones.append("opened window")
    if "enter window" in game_history:
        milestones.append("entered house")
    if "get lantern" in game_history or "take lantern" in game_history:
        milestones.append("got lantern")
    if "get knife" in game_history or "take knife" in game_history:
        milestones.append("got knife")
    return ", ".join(milestones) if milestones else "No milestones achieved."
