def extract_state(game_history):
    history = game_history.lower()
    milestones = []
    if "read paper" in history:
        milestones.append("Read paper")
    if "read note" in history:
        milestones.append("Read note")
    if "take gun" in history:
        milestones.append("Took gun")
    if "you have died" in history:
        milestones.append("Died")
    if milestones:
        return ", ".join(milestones) + "."
    else:
        return "Unknown state."
