def extract_state(game_history):
    import re
    milestones = []
    if re.search(r'\bread paper\b', game_history, re.I):
        milestones.append('Read paper')
    if re.search(r'\bread note\b', game_history, re.I):
        milestones.append('Read note')
    if re.search(r'\bexamine wood\b', game_history, re.I):
        milestones.append('Examine wood')
    if re.search(r'\bupstairs hallway\b', game_history, re.I):
        milestones.append('Explored upstairs hallway')
    if re.search(r'\bguest room\b', game_history, re.I):
        milestones.append('Explored guest rooms')
    if re.search(r'\bmaster ring\b', game_history, re.I):
        milestones.append('Got master ring')
    if re.search(r'\broom #30\b', game_history, re.I):
        milestones.append('Found room #30')
    if re.search(r'\bup\b', game_history, re.I) and re.search(r'room #30', game_history, re.I):
        milestones.append('Exited room #30')
    if re.search(r'\byou have won\b', game_history, re.I):
        milestones.append('Game finished')
    if not milestones:
        return 'Unknown state.'
    return '; '.join(milestones)
