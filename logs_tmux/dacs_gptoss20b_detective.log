def extract_state(game_history):
    lower = game_history.lower()
    parts = []
    if "read paper" in lower:
        parts.append("Read paper")
    if "read note" in lower:
        parts.append("Read note")
    if "mayor's house" in lower or "mayor's house" in lower:
        parts.append("Entered mayor's house")
    if "upstairs hallway" in lower or "upstairs" in lower:
        parts.append("Explored upstairs hallway")
    if "living room" in lower:
        parts.append("Explored living room")
    if "dining room" in lower:
        parts.append("Explored dining room")
    if "music store" in lower:
        parts.append("In music store")
    if "*** you have died ***" in lower:
        parts.append("Agent died")
    if not parts:
        return "Unknown state."
    return "; ".join(parts) + "."
