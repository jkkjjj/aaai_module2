def extract_state(game_history):
    milestones = set()
    for line in game_history.splitlines():
        if line.lower().startswith("extracted state:"):
            items = [item.strip() for item in line[len("EXTRACTED STATE:"):].split(";")]
            for item in items:
                if item:
                    milestones.add(item.lower())
    summary = []
    if "lantern acquired" in milestones:
        summary.append("Lantern acquired")
    if "lantern lit" in milestones or "lamp is now on" in milestones:
        summary.append("Lantern lit")
    if "junction visited" in milestones:
        summary.append("Junction reached")
    if "rope used" in milestones:
        summary.append("Rope used")
    if "sword examined" in milestones:
        summary.append("Sword examined")
    if "sword acquired" in milestones or "sword appears in your hand" in milestones:
        summary.append("Sword acquired")
    if "hooded figure bypassed" in milestones:
        summary.append("Hooded figure bypassed")
    if "chest examined" in milestones:
        summary.append("Chest examined")
    if "chest searched" in milestones:
        summary.append("Chest searched")
    return ", ".join(summary) if summary else "Unknown state."
