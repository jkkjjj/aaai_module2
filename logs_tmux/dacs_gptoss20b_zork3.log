def extract_state(game_history):
    lantern_lit = "lamp" in game_history or "lantern" in game_history
    lantern_lit = lantern_lit and ("is on" in game_history or "illuminated" in game_history)
    sword_embedded = "elvish sword" in game_history and ("not budge" in game_history or "deeply imbedded" in game_history)
    chest_locked = "large chest" in game_history and ("closed" in game_history or "locked" in game_history)
    hooded_figure = "hooded figure" in game_history or "cloaked" in game_history
    north_open = "north" in game_history and ("open" in game_history or "crumbled" in game_history)
    summary_parts = []
    if lantern_lit:
        summary_parts.append("Lantern acquired and lit")
    if sword_embedded:
        summary_parts.append("Sword embedded in rock, not taken")
    if chest_locked:
        summary_parts.append("Locked chest on cliff ledge discovered")
    if hooded_figure:
        summary_parts.append("Hooded figure blocks east exit")
    if north_open:
        summary_parts.append("North direction open")
    return ". ".join(summary_parts) + "."
