def extract_state(game_history):
    s = game_history.lower()
    parts = []
    if "take lantern" in s or "lantern" in s:
        parts.append("Lantern taken")
    if "light lantern" in s or "lamp is now on" in s:
        parts.append("Lantern lit")
    if "climb rope" in s:
        parts.append("Rope climbed, at cliff ledge")
    if "examine chest" in s or "chest" in s:
        parts.append("Chest seen")
    if "open chest" in s or "chest opened" in s:
        parts.append("Chest opened")
    if "defeat" in s or "fight" in s or "down on the ground" in s:
        parts.append("Figure defeated")
    if not parts:
        return "Unknown state."
    return ", ".join(parts)
