def extract_state(game_history):
    lantern = "lantern" in game_history.lower()
    lantern_lit = "lamp is now on" in game_history.lower() or "lamp is now lit" in game_history.lower() or "lamp is lit" in game_history.lower()
    junction = "junction" in game_history.lower()
    sword_taken = "take sword" in game_history.lower() and "the sword is deeply imbedded" not in game_history.lower()
    rope_used = "climb rope" in game_history.lower()
    chest_explored = "examine chest" in game_history.lower() or "search chest" in game_history.lower()
    hooded_figure_bypassed = "north" in game_history.lower() and "crumbled wall" in game_history.lower()
    wounded = "wounded" in game_history.lower() or "hit" in game_history.lower()
    inventory_check = "inventory" in game_history.lower()
    summary = []
    if lantern:
        summary.append("lantern acquired")
    if lantern_lit:
        summary.append("lantern lit")
    if junction:
        summary.append("junction visited")
    if sword_taken:
        summary.append("sword taken")
    if rope_used:
        summary.append("rope used")
    if chest_explored:
        summary.append("chest examined")
    if hooded_figure_bypassed:
        summary.append("hooded figure bypassed")
    if wounded:
        summary.append("wounded")
    if inventory_check:
        summary.append("inventory checked")
    return "; ".join(summary) if summary else "No milestones found."
