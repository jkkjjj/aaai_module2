def extract_state(game_history):
    # Normalize text for easier matching
    text = game_history.lower()
    
    # Check for key acquisition
    key_found = False
    if ("you find a key" in text
        or "you find a small key" in text
        or "you find something that looks like a key" in text):
        key_found = True
    
    # Check if key is in inventory
    key_in_inventory = False
    if "you are carrying" in text:
        if "key" in text:
            key_in_inventory = True
    
    # Check if door is unlocked
    door_unlocked = False
    if ("unlock" in text and "door" in text and ("you open" in text or "you unlocked" in text)):
        door_unlocked = True
    # Some games may say the door is unlocked in the description
    if "the main entrance" in text and "unlocked" in text:
        door_unlocked = True
    
    # Check if the agent has entered the building
    entered = False
    if ("you enter" in text or "you step inside" in text or "you enter the building" in text):
        entered = True
    
    # Build summary
    parts = []
    if key_found:
        parts.append("Key found")
    else:
        parts.append("Key not found")
    if key_in_inventory:
        parts.append("Key in inventory")
    else:
        parts.append("Key not in inventory")
    if door_unlocked:
        parts.append("Door unlocked")
    else:
        parts.append("Door locked")
    if entered:
        parts.append("Entered building")
    else:
        parts.append("Outside")
    
    return ", ".join(parts) + "."
