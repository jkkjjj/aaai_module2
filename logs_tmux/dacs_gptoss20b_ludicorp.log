def extract_state(game_history):
    history = game_history.lower()
    milestones = []

    if ("you find a key" in history or "you find a small key" in history or
        "you find something that looks like a key" in history):
        milestones.append("Key found")

    if ("you are carrying" in history and "key" in history):
        milestones.append("Key in inventory")

    if ("unlock door with key" in history or "unlock door key" in history or
        "unlock door" in history and "you open" in history):
        milestones.append("Door unlocked")

    if ("you enter" in history or "you step inside" in history):
        milestones.append("Entered building")

    if not milestones:
        return "Unknown state."

    return ", ".join(milestones) + "."
