    door_unlocked = 'swings open' in game_history.lower()
    cabinet_opened = 'you open cabinet' in game_history.lower() or 'opened cabinet' in game_history.lower()
    sword_acquired = ('sword' in game_history.lower() and 'taken' in game_history.lower()) or 'get sword' in game_history.lower()
    shield_acquired = ('shield' in game_history.lower() and 'taken' in game_history.lower()) or 'get shield' in game_history.lower()
    guard_post_visited = 'northern guard post' in game_history.lower()
    main_hall_entered = 'main hall' in game_history.lower()
    note_read = 'king\'s order' in game_history.lower() or 'note reads' in game_history.lower()
    library_accessed = 'library' in game_history.lower() or 'tome' in game_history.lower()
    
    parts = []
    if door_unlocked: parts.append('door unlocked')
    if cabinet_opened: parts.append('cabinet opened')
    if sword_acquired: parts.append('sword obtained')
    if shield_acquired: parts.append('shield obtained')
    if guard_post_visited: parts.append('guard post visited')
    if main_hall_entered: parts.append('main hall entered')
    if note_read: parts.append('note read')
    if library_accessed: parts.append('library accessed')
    else: parts.append('library not accessed')
    
    return ', '.join(parts) + '.'
