def extract_state(game_history):
    history = game_history.lower()
    parts = []
    if "swings open" in history or "door swings open" in history:
        parts.append("door unlocked")
    if "open cabinet" in history or "opened cabinet" in history:
        parts.append("cabinet opened")
    if "take sword" in history or "you take sword" in history:
        parts.append("sword obtained")
    if "take shield" in history or "you take shield" in history:
        parts.append("shield obtained")
    if "main hall" in history and "you are met by an imposing" in history:
        parts.append("main hall entered")
    if "read note" in history or "king's order" in history or "note reads" in history:
        parts.append("note read")
    if "take bottle" in history or "you take bottle" in history:
        parts.append("bottle taken")
    if "railway station" in history:
        parts.append("railway station visited")
    if "main street" in history:
        parts.append("main street visited")
    if "northern guard post" in history or "eastern guard post" in history:
        parts.append("guard post visited")
    if "dwarven library" in history:
        parts.append("library visited")
    if "open opening" in history or "enter opening" in history:
        parts.append("small opening attempted")
    return ', '.join(parts) + '.'
