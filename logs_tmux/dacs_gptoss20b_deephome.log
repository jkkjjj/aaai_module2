def extract_state(game_history):
    door_unlocked = ('door swings open' in game_history or
                     'you can see the door open' in game_history or
                     'the heavy door stands open' in game_history)
    cabinet_opened = ('open cabinet' in game_history or
                      'opened cabinet' in game_history)
    sword_acquired = ('get sword' in game_history or
                      'taken sword' in game_history or
                      ('sword' in game_history and 'taken' in game_history))
    shield_acquired = ('get shield' in game_history or
                       'taken shield' in game_history or
                       ('shield' in game_history and 'taken' in game_history))
    letter_read = ('examine letter' in game_history or
                   'read letter' in game_history or
                   'letter reads' in game_history)
    note_read = ('examine note' in game_history or
                 'read note' in game_history or
                 'note reads' in game_history)
    main_hall = 'main hall' in game_history
    library_accessed = ('library' in game_history or
                        'tome' in game_history or
                        'library entrance' in game_history)
    
    parts = []
    if door_unlocked: parts.append('door unlocked')
    if cabinet_opened: parts.append('cabinet opened')
    if sword_acquired: parts.append('sword acquired')
    if shield_acquired: parts.append('shield acquired')
    if letter_read: parts.append('letter read')
    if note_read: parts.append('note read')
    if main_hall: parts.append('main hall entered')
    if library_accessed: parts.append('library accessed')
    else: parts.append('library not accessed')
    
    return ', '.join(parts) + '.'
```'

