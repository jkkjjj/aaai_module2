   - If still stuck, backtrack to the previous room and try another unexplored exit.

**State Extractor Code**'
def extract_state(game_history):
    # Normalize to lowercase for easier matching
    h = game_history.lower()
    milestones = []

    # Door status
    if "door swings open" in h or "door opens" in h:
        milestones.append("door opened")

    # Cabinet
    if "open cabinet" in h or "opened cabinet" in h:
        milestones.append("cabinet opened")
    if "you take sword" in h or "taken sword" in h:
        milestones.append("sword taken")
    if "you take shield" in h or "taken shield" in h:
        milestones.append("shield taken")

    # Note
    if "read note" in h or "note reads" in h or "king's order" in h:
        milestones.append("note read")

    # Railcar
    if "railcar" in h:
        milestones.append("railcar seen")
    if "examined railcar" in h or "examine railcar" in h:
        milestones.append("railcar examined")
    if "open door" in h and "railcar" in h:
        milestones.append("railcar door opened")
    if "press yellow" in h or "press green" in h or "press red" in h:
        milestones.append("power button pressed")

    # Inventory
    inventory = []
    if "sword taken" in h:
        inventory.append("sword")
    if "shield taken" in h:
        inventory.append("shield")

    # Compose summary
    summary_parts = []
    if milestones:
        summary_parts.append(", ".join(sorted(set(milestones))))
    if inventory:
        summary_parts.append("inventory: " + ", ".join(sorted(inventory)))
    if not summary_parts:
        return "No significant milestones yet."
    return ". ".join(summary_parts) + "."
