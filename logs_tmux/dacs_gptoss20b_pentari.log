def extract_state(game_history):
    # Determine key milestones
    postcard_read = "read postcard" in game_history.lower()
    sword_in_inventory = "sword" in game_history.lower()
    door_inspected = any(cmd in game_history.lower() for cmd in ["examine door", "look at door", "search door"])
    drawers_inspected = all(f"open drawer{n}" in game_history.lower() for n in range(1,5))
    dresser_examined = "examine dresser" in game_history.lower()
    bed_searched = any(cmd in game_history.lower() for cmd in ["search bed", "look at bed"])
    chest_examined = "examine chest" in game_history.lower()
    door_opened = "open door" in game_history.lower()
    # Build summary
    parts = []
    if postcard_read:
        parts.append("Postcard read")
    if sword_in_inventory:
        parts.append("Sword in inventory")
    if door_inspected:
        parts.append("Door inspected")
    if dresser_examined:
        parts.append("Dresser examined")
    if drawers_inspected:
        parts.append("All drawers inspected")
    if bed_searched:
        parts.append("Bed searched")
    if chest_examined:
        parts.append("Chest examined")
    if door_opened:
        parts.append("Door opened")
    if not parts:
        return "No significant progress."
    return "; ".join(parts) + "."
