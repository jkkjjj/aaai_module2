**State extractor**'
def extract_state(game_history):
    state = ""
    if "key" in game_history and "in inventory" in game_history:
        state += "Key in inventory. "
    if "sword" in game_history and "in inventory" in game_history:
        state += "Sword in inventory. "
    if "scroll" in game_history and "unused" in game_history:
        state += "Scroll unused. "
    if "used" in game_history and "scroll" in game_history:
        state += "Scroll used. "
    if "library" in game_history and "you are in library" not in game_history:
        # find last location mention
        last = None
        for line in reversed(game_history.splitlines()):
            if "library" in line.lower():
                last = line.strip()
                break
        if last:
            state += f"Current location: {last}. "
    if "exit" in game_history and "found" in game_history:
        state += "Exit found. "
    if not state:
        state = "No significant progress detected."
    return state.strip()
