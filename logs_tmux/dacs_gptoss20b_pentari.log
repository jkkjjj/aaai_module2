def extract_state(game_history):
    h = game_history.lower()
    if "exited the quarters" in h:
        return "Exited quarters."
    if "key found" in h or "found key" in h or "you have a key" in h:
        return "Found key."
    if "door unlocked" in h or "door opens" in h or "open door" in h:
        return "Door opened."
    return "In quarters, no key or door action."
```'
def extract_state(game_history):
    sword_acquired = "fine pentarian sword" in game_history
    postcard_acquired = "postcard" in game_history
    dresser_examined = "dresser" in game_history or "chest" in game_history
    drawer_examined = "drawer" in game_history
    door_examined = "door" in game_history
    key_found = "key" in game_history
    exit_opened = "open door" in game_history or "open window" in game_history
    if exit_opened:
        return "Exited the quarters, entering next area."
    parts = []
    if sword_acquired:
        parts.append("Sword in inventory")
    if postcard_acquired:
        parts.append("Postcard examined")
    if dresser_examined:
        parts.append("Dresser inspected")
    if drawer_examined:
        parts.append("Drawer inspected")
    if door_examined:
        parts.append("Door inspected")
    if key_found:
        parts.append("Key found")
    if not parts:
        return "No significant progress yet."
    return "; ".join(parts) + "."
