def extract_state(game_history):
    milestones = []
    # Entered transporter
    if "enter transporter" in game_history.lower():
        milestones.append("Entered transporter")
    # Arrived at city
    if "city" in game_history.lower() and "entered transporter" in game_history.lower():
        milestones.append("Arrived city")
    # Entered entrance hall
    if "entrance hall" in game_history.lower():
        milestones.append("Entered entrance hall")
    # Entered library
    if "library" in game_history.lower():
        milestones.append("Entered library")
    # Encountered wizard morden
    if "wizard morden" in game_history.lower():
        milestones.append("Encountered wizard morden")
    # Used scroll
    if "use scroll" in game_history.lower():
        milestones.append("Used scroll")
    if not milestones:
        return "No milestones"
    return ", ".join(milestones)
