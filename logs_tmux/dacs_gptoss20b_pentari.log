    if dresser_examined:
        parts.append("Dresser inspected")
    if drawer_examined:
        parts.append("Drawer inspected")
    if door_examined:
        parts.append("Door inspected")
    if key_found:
        parts.append("Key found")
    if not parts:
        return "No significant progress yet."
    return "; ".join(parts) + "."
