def extract_state(game_history):
    found_scroll = "shiny scroll" in game_history
    read_scroll = "the scroll reads" in game_history
    inventory = "you are carrying" in game_history
    location = "pocket valley" if "pocket valley" in game_history else "unknown"
    horse = "chestnut horse" in game_history
    summary_parts = []
    if found_scroll:
        summary_parts.append("found scroll")
    if read_scroll:
        summary_parts.append("read scroll")
    if inventory:
        summary_parts.append("carrying items")
    summary_parts.append(f"location: {location}")
    if horse:
        summary_parts.append("horse present")
    return ", ".join(summary_parts)
