def extract_state(game_history):
    import re
    # Current location
    last_state = ""
    for part in re.findall(r"STATE:\s*(.*?)\n", game_history, flags=re.S):
        if part.strip():
            last_state = part.strip()
    location = "unknown"
    if "pocket valley" in last_state.lower():
        location = "pocket valley"
    elif "grasslands" in last_state.lower():
        location = "grasslands"
    elif "hut" in last_state.lower():
        location = "hut"
    # Scroll status
    scroll_found = "shiny scroll" in game_history.lower()
    scroll_read = "the scroll reads" in game_history.lower()
    scroll_in_inventory = "you are carrying" in game_history.lower() and "shiny scroll" in game_history.lower()
    # Horse status
    horse_present = "chestnut horse" in game_history.lower()
    horse_wings = False
    if "sprout wings" in game_history.lower() or "wing" in game_history.lower():
        horse_wings = True
    # Build summary
    parts = [f"Location: {location}"]
    if scroll_found:
        parts.append("Scroll found")
    if scroll_read:
        parts.append("Scroll read")
    if scroll_in_inventory:
        parts.append("Scroll in inventory")
    if horse_present:
        parts.append("Horse present")
    if horse_wings:
        parts.append("Horse wings sprouted")
    else:
        parts.append("Horse wings not sprouted")
    return "; ".join(parts)
