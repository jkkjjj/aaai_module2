        loc = "ramshackle hut"

    # Milestones
    scroll_found = "shiny scroll" in game_history
    scroll_read = "the scroll reads" in game_history
    horse_present = "chestnut horse" in game_history
    horse_wings = ("wing" in game_history or "sprout wings" in game_history) and "horse" in game_history

    parts = [f"Location: {loc}"]
    if scroll_found:
        parts.append("Scroll found")
    if scroll_read:
        parts.append("Scroll read")
    if horse_present:
        parts.append("Horse present")
    if horse_wings:
        parts.append("Horse wings")
    else:
        if horse_present:
            parts.append("Horse wings: no")
    return "; ".join(parts)
