def extract_state(game_history):
    import re
    # Get the last STATE block
    states = re.findall(r"STATE:\s*(.*?)\n", game_history, flags=re.S)
    last_state = states[-1] if states else ""
    # Current location
    if "pocket valley" in last_state:
        location = "pocket valley"
    elif "grasslands, near hut" in last_state:
        location = "grasslands, near hut"
    else:
        location = "unknown"
    # Milestones
    scroll_found = "shiny scroll" in game_history
    scroll_read = "the scroll reads" in game_history
    horse_present = "chestnut horse" in game_history
    horse_wings = "wing" in game_history or "sprout wings" in game_history
    # Build summary
    parts = [f"Location: {location}"]
    if scroll_found:
        parts.append("Scroll found")
    if scroll_read:
        parts.append("Scroll read")
    if horse_present:
        parts.append("Horse present")
    if horse_wings:
        parts.append("Horse wings")
    return "; ".join(parts)
