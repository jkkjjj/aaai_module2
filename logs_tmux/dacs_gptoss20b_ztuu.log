def extract_state(game_history):
    loc = "unknown"
    if "You are standing at the entrance of the new excavation" in game_history:
        loc = "tunnel"
    elif "cultural complex" in game_history:
        loc = "cultural complex"
    elif "convention center lobby" in game_history:
        loc = "convention center lobby"
    lantern = "none"
    if "you are carrying" in game_history:
        if "brass lantern" in game_history:
            lantern = "brass lantern"
            if "providing light" in game_history:
                lantern = lantern + " (lit)"
            else:
                lantern = lantern + " (unlit)"
    guard = "absent"
    if "guard" in game_history or "bouncer" in game_history:
        guard = "present"
    door = "closed"
    if "north door opens" in game_history or "door opens" in game_history:
        door = "open"
    return f"Location: {loc}. Lantern: {lantern}. Guard: {guard}. Door: {door}."
