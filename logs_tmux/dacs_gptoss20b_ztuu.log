def extract_state(game_history):
    if "*** you have died ***" in game_history:
        return "Player died."
    lantern_lit = "lantern is already on." in game_history.lower() or "lantern is lit" in game_history.lower()
    lantern_dropped = "dropped." in game_history.lower()
    lantern_held = "you have" in game_history.lower() and "lantern" in game_history.lower() and not lantern_dropped
    tunnel_entered = "entrance of a narrow, waist-high tunnel" in game_history
    lobby_entered = "convention center lobby" in game_history
    parts = []
    if tunnel_entered:
        parts.append("Entered tunnel")
    if lobby_entered:
        parts.append("Entered lobby")
    if lantern_lit:
        parts.append("Lantern lit")
    if lantern_held:
        parts.append("Lantern held")
    if lantern_dropped:
        parts.append("Lantern dropped")
    if "north" in game_history.lower() and "door" in game_history.lower() and "open" in game_history.lower():
        parts.append("Attempted to move north")
    return ", ".join(parts) if parts else "Unknown state."
