def extract_state(game_history):
    gh = game_history.lower()
    milestones = []
    if "you are standing at the entrance of a narrow" in gh:
        milestones.append("Entered tunnel")
    if "you are standing at the entrance of the cultural complex" in gh:
        milestones.append("Entered cultural complex")
    if "you are standing at the entrance of the gue convention center" in gh:
        milestones.append("Entered lobby")
    if "the lantern is already on" in gh or "you light lantern" in gh:
        milestones.append("Lantern lit")
    if "drop lantern" in gh or "dropped" in gh:
        milestones.append("Lantern dropped")
    if "north" in gh and "you are standing at the entrance of the gue convention center" in gh:
        if "you have died" in gh or "you died" in gh or "grue" in gh:
            milestones.append("Attempted north; died")
        else:
            milestones.append("Attempted north")
    return ", ".join(milestones) if milestones else "Unknown state."
