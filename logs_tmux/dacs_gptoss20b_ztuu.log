def extract_state(game_history):
    history = game_history.lower()
    location = "unknown"
    rooms = ["tunnel", "cultural complex", "convention center lobby", "hall of science", "royal theater", "underground entrance", "darkness"]
    for r in rooms:
        if r in history:
            location = r
    lantern_in_hand = "get lantern" in history and "dropped." not in history
    lantern_on_ground = "drop lantern" in history or "you can see a brass lantern" in history
    guard_present = "guard" in history or "bouncer" in history
    door_open = "door opens" in history or "north door is open" in history
    dead = "you have died" in history
    summary = f"Location: {location}. "
    if lantern_in_hand:
        summary += "Lantern in inventory. "
    elif lantern_on_ground:
        summary += "Lantern on the ground. "
    else:
        summary += "Lantern not found. "
    summary += "Guard present. " if guard_present else ""
    summary += "North door open. " if door_open else "North door closed. "
    summary += "Dead." if dead else "Alive."
    return summary
