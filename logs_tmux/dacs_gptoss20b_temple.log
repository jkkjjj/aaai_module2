def extract_state(game_history):
    lh = game_history.lower()
    loc = None
    if "study" in lh:
        loc = "study"
    elif "storage" in lh:
        loc = "storage"
    elif "roof" in lh:
        loc = "roof"

    items = []
    if "yellow paper" in lh:
        items.append("yellow paper")
    if "vial" in lh and "vials" in lh:
        items.append("vials")
    if "powder" in lh:
        items.append("powder")

    npc = None
    if "man appears" in lh or "man on table" in lh:
        npc = "man"

    success = "coded message" in lh or "revealed" in lh

    state = f"Location: {loc or 'unknown'}; Items: {', '.join(items) if items else 'none'}; NPC: {npc or 'none'}; Success: {success}"
    return state
