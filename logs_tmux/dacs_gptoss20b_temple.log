def extract_state(game_history):
    state = "Unknown state."
    if "yellow paper" in game_history and "vial" in game_history:
        inventory_pass = "inventory" in game_history
        if inventory_pass:
            state = "In study, inventory: yellow paper, four vials of green powder; coded message unread, attempted to apply powder but no success."
        else:
            state = "In study, yellow paper and vials collected; coded message unread."
    elif "yellow paper" in game_history:
        state = "Yellow paper collected; vials not yet collected."
    elif "vial" in game_history:
        state = "Green powder vials collected; yellow paper not yet found."
    return state
